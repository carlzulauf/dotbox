+static void cvs_delayed_release(struct work_struct *work)
+{
+	struct intel_cvs *icvs = container_of(work,
+		struct intel_cvs, delayed_release.work);
+
+	if (!icvs)
+		return;
+
+	dev_info(icvs->dev, "%s: Auto-releasing sensor", __func__);
+
+	/* Only release if IPU owns the sensor and refcount is 1 */
+	if (icvs->owner == CVS_CAMERA_IPU && icvs->int_ref_count == 1) {
+		int ret = cvs_release_camera_sensor_internal();
+		if (ret)
+			dev_warn(icvs->dev, "%s: Release failed: %d", __func__, ret);
+		else
+			icvs->icvs_sensor_state = CV_SENSOR_RELEASED_STATE;
+	}
+
+	dev_info(icvs->dev, "%s: Sensor released, LED should turn off", __func__);
+}
