+static struct intel_cvs *cvs_get_icvs_from_dev(struct device *dev)
+{
+	struct i2c_client *i2c = to_i2c_client(dev);
+	return i2c_get_clientdata(i2c);
+}
+
+static ssize_t sensor_owner_show(struct device *dev,
+				  struct device_attribute *attr, char *buf)
+{
+	struct intel_cvs *icvs = cvs_get_icvs_from_dev(dev);
+	if (!icvs)
+		return -EINVAL;
+	if (icvs->owner == CVS_CAMERA_IPU)
+		return sysfs_emit(buf, "ipu\n");
+	else
+		return sysfs_emit(buf, "cvs\n");
+}
+
+static ssize_t sensor_owner_store(struct device *dev,
+				   struct device_attribute *attr,
+				   const char *buf, size_t count)
+{
+	struct intel_cvs *icvs = cvs_get_icvs_from_dev(dev);
+	int ret;
+
+	if (!icvs)
+		return -EINVAL;
+
+	if (sysfs_streq(buf, "ipu")) {
+		/* Cancel any pending delayed release */
+		cancel_delayed_work_sync(&icvs->delayed_release);
+		ret = cvs_acquire_camera_sensor_internal();
+		if (ret)
+			return ret;
+		icvs->icvs_sensor_state = CV_SENSOR_VISION_ACQUIRED_STATE;
+		dev_info(dev, "%s: sensor acquired by IPU", __func__);
+	} else if (sysfs_streq(buf, "cvs")) {
+		ret = cvs_release_camera_sensor_internal();
+		if (ret)
+			return ret;
+		icvs->icvs_sensor_state = CV_SENSOR_RELEASED_STATE;
+		dev_info(dev, "%s: sensor released to CVS", __func__);
+	} else {
+		return -EINVAL;
+	}
+
+	return count;
+}
+
+static DEVICE_ATTR_RW(sensor_owner);
